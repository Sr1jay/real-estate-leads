generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          Int      @id @default(autoincrement())
  name        String?
  phone       String
  projectName String?
  source      String?
  status      String   @default("new")
  notes       String?
  createdAt   DateTime @default(now())
}
