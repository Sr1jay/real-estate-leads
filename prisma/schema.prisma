generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          Int         @id @default(autoincrement())
  name        String?
  phone       String
  projectName String?
  source      String?
  status      String      @default("new")
  notes       String?
  followUpAt  DateTime?
  createdAt   DateTime    @default(now())
  leadNotes   LeadNote[]
}

model LeadNote {
  id        Int      @id @default(autoincrement())
  leadId    Int
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
